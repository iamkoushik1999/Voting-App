NODE_ENV=development
PORT=5050

# MongoDB Atlas (or any Mongo) connection string
MONGODB_URL=

# Long random string used to sign JWTs
JWT_SECRET=

# Seeds/updates the single admin account on every server start
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Only used in development, to allow the Vite dev server to send credentialed requests
CLIENT_URL=http://localhost:5173
